{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "changelog-sections": [
    { "type": "feat", "section": "Added" },
    { "type": "fix", "section": "Fixed" },
    { "type": "perf", "section": "Changed" },
    { "type": "docs", "section": "Documentation" },
    { "type": "ci", "section": "Infrastructure" },
    { "type": "chore", "section": "Infrastructure", "hidden": true },
    { "type": "style", "section": "Changed", "hidden": true },
    { "type": "test", "section": "Infrastructure", "hidden": true },
    { "type": "refactor", "section": "Changed", "hidden": true },
    { "type": "build", "section": "Infrastructure", "hidden": true }
  ],
  "packages": {
    ".": {
      "release-type": "node",
      "exclude-paths": [
        "README.md",
        "docs/**",
        "LICENSE",
        "assets/screenshots/**"
      ]
    }
  }
}
